SERVER=LOCAL

DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.localhost,.trayza.in
DJANGO_LOG_LEVEL=INFO

CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_ORIGIN_REGEXES=^http://.*\.localhost:5173$,^https://.*\.trayza\.in$
CORS_ALLOW_ALL_ORIGINS=False

DB_ENGINE=django_tenants.postgresql_backend
DB_NAME=radha
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

JWT_SIGNING_KEY=replace-with-a-long-random-jwt-signing-key
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14
JWT_ROTATE_REFRESH_TOKENS=True
LOGIN_THROTTLE_RATE=10/minute
TOKEN_REFRESH_THROTTLE_RATE=30/minute
PASSWORD_RESET_THROTTLE_RATE=5/minute
DEFAULT_FROM_EMAIL=no-reply@localhost
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/reset-password
PASSWORD_RESET_RETURN_TOKEN=False

SAAS_ROOT_DOMAIN=localhost
SHOW_PUBLIC_IF_NO_TENANT_FOUND=True

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
CSRF_TRUSTED_ORIGINS=https://admin.trayza.in,https://*.trayza.in

# Uploaded logos/files. In production, keep MEDIA_ROOT aligned with the
# Nginx /media/ alias.
MEDIA_URL=/media/
MEDIA_ROOT=/var/www/radha/media
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
BUSINESS_PROFILE_LOGO_MAX_BYTES=2097152
BUSINESS_PROFILE_LOGO_ALLOWED_TYPES=image/jpeg,image/png,image/webp

APP_DIR=
VENV_PATH=.venv/bin/activate
GUNICORN_BIND=127.0.0.1:8006
